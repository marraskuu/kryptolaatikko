# Railway Variables (web-palvelu)

SECRET_KEY=generoi-pitka-satunnainen-avain

DEBUG=false

# ALLOWED_HOSTS — valinnainen. Ilman tätä: localhost + RAILWAY_PUBLIC_DOMAIN + CUSTOM_DOMAIN.
# ALLOWED_HOSTS=hiekkalaatikko.pro,www.hiekkalaatikko.pro

# Admin-API (/api/admin/...) — valinnainen. Ilman tätä tuotannossa johdetaan SECRET_KEY:stä:
# python -c "import hashlib; print(hashlib.sha256(b'admin-task:YOUR_SECRET').hexdigest())"
# ADMIN_TASK_KEY=

# Oma domain (Railway custom domain)

CUSTOM_DOMAIN=hiekkalaatikko.pro



# Django admin — luodaan automaattisesti deployssa (ensure_superuser)
# Aseta Railway Variables, redeploy, kirjaudu https://hiekkalaatikko.pro/admin/
# Voit poistaa PASSWORD-muuttujan luonnin jälkeen (käyttäjä jää tietokantaan).
# DJANGO_SUPERUSER_USERNAME=chris
# DJANGO_SUPERUSER_PASSWORD=valitse-pitka-satunnainen-salasana
# DJANGO_SUPERUSER_EMAIL=chris@example.com
# DJANGO_SUPERUSER_RESET=1   # vain jos haluat päivittää salasanan uudelleen



# Sentry — virheseuranta (https://sentry.io → Create Project → Django)
# SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.05   # valinnainen: 5 % pyynnöistä (0 = vain virheet)
# SENTRY_PROFILES_SAMPLE_RATE=0



# Google Gemini — AI Studio API key (AIzaSy… tai uusi AQ.… -muoto)
# Hae: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Halvin malli — lite riittää, tekninen analyysi tekee raskaan työn
GEMINI_MODEL=gemini-2.5-flash-lite

# Älä yritä kalliimpia malleja automaattisesti (1 = sallittu)
# GEMINI_ALLOW_FALLBACK=0

# Kuinka usein Geminiä kutsutaan (sekunteina). 600 = 10 min.
# Tekninen analyysi (stop-loss, voitto-myynti) pyörii silti joka 60 s.
GEMINI_INTERVAL_SEC=600

# Oppimisraportin Gemini-narratiivi (sekunteina). 21600 = 6 h.
LEARNING_REPORT_INTERVAL_SEC=21600
# Gemini-uudelleenyritys virheen jälkeen (sekunteina). 600 = 10 min.
NARRATIVE_ERROR_RETRY_SEC=600

# Botti uptime-laskenta (valinnainen ISO-aika, esim. 2026-06-10T12:00:00+00:00)
# BOT_STARTED_AT=



# Kävijätilastot — https://hiekkalaatikko.pro/stats/ (superuser-kirjautuminen)
# Sama tunnus kuin DJANGO_SUPERUSER_USERNAME / DJANGO_SUPERUSER_PASSWORD

# MySQL — Railway: lisää Reference Variable MySQL-palvelusta → MYSQL_URL
# DATABASE_URL=${{MySQL.MYSQL_URL}}
# Älä jätä tyhjää tai rikkinäistä DATABASE_URL:ia — se kaataa deployn.



# Paikallinen MySQL (valinnainen)

# DATABASE_URL=mysql://root:salasana@127.0.0.1:3306/kryptolaatikko



# Historiallinen varjo-oppiminen (Bitfinex 1h-kynttilät)

# BACKFILL_TOP_SYMBOLS=20
# BACKFILL_CANDLE_LIMIT=5000
# HISTORY_BACKFILL_INTERVAL_SEC=604800

# Historiallinen setup-oppiminen (round-trip backtest samoilla kynttilöillä)

# SETUP_HIST_WEIGHT=0.3
# SETUP_MIN_ENTRY_SCORE=2
# SETUP_MAX_HOLD_HOURS=72

# Order book + long/short positioning (Bitfinex public API)
# MICROSTRUCTURE_ENABLED=1
# MICROSTRUCTURE_BOOK_LIMIT=12
# MIN_BID_DEPTH_ENTRY_EUR=40000   # ostovelkainen ennen uutta ostoa (jumi-riski)
# MIN_ASK_DEPTH_ENTRY_EUR=40000   # myyntitarjonta ennen ostoa
# MIN_BID_DEPTH_HOLDING_EUR=15000   # minimi ostovelkainen omistuksen aikana
# HOLDING_DEPTH_POSITION_RATIO=2.5  # ostovelk. ≥ ratio × positioarvo
# MICROSTRUCTURE_STATS_LIMIT=8
# MICROSTRUCTURE_STATS_TTL_SEC=300
# MICROSTRUCTURE_STATS_PER_CYCLE=3     # crowd-refresh per 60 s sykli (holdings ensin)
# MICROSTRUCTURE_HOLDINGS_EXIT_BOOK=1  # tuore order book 15 s voitto-polulla
# TRADE_FLOW_ENABLED=1
# TRADE_FLOW_LIMIT=120
# TRADE_FLOW_WINDOW_1M_SEC=60
# TRADE_FLOW_WINDOW_5M_SEC=300

# Karhu-puolustus — vähemmän tappiollisia rotaatio-/aikastoppi-/ostoja laskevassa markkinassa
# BEAR_DEFENSE_ENABLED=1
# BEAR_MIN_CASH_SHARE=0.25          # karhu-kassavara: tavoite % käteistä salkusta
# BEAR_CASH_TRIM_ENABLED=1          # trimmaa positioita jos kassavara alle tavoitteen
# BEAR_CASH_TRIM_MAX_FRACTION=0.5   # max osuus yhdestä positioista per trim-kierros
# BEAR_STAGNANT_MIN_LOSS_PCT=-0.75  # aikastoppi vain syvemmästä tappiosta (norm. -0.25 %)
# BEAR_STAGNANT_HOURS=7.0           # pidempi aikastoppi karhussa (norm. 5 h)
# BEAR_STUCK_POSITION_HOURS=6.0     # jumitusta pidempään ennen myyntiä (norm. 4 h)

