# Railway Variables (web-palvelu)

SECRET_KEY=generoi-pitka-satunnainen-avain

DEBUG=false

ALLOWED_HOSTS=*



# Oma domain (Railway custom domain)

CUSTOM_DOMAIN=hiekkalaatikko.pro



# Django admin — luodaan automaattisesti deployssa (ensure_superuser)
# Aseta Railway Variables, redeploy, kirjaudu https://hiekkalaatikko.pro/admin/
# Voit poistaa PASSWORD-muuttujan luonnin jälkeen (käyttäjä jää tietokantaan).
# DJANGO_SUPERUSER_USERNAME=chris
# DJANGO_SUPERUSER_PASSWORD=valitse-pitka-satunnainen-salasana
# DJANGO_SUPERUSER_EMAIL=chris@example.com
# DJANGO_SUPERUSER_RESET=1   # vain jos haluat päivittää salasanan uudelleen



# Sentry — virheseuranta (https://sentry.io → Create Project → Django)
# SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.05   # valinnainen: 5 % pyynnöistä (0 = vain virheet)
# SENTRY_PROFILES_SAMPLE_RATE=0



# Google Gemini — AI Studio API key (AIzaSy… tai uusi AQ.… -muoto)
# Hae: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Halvin malli — lite riittää, tekninen analyysi tekee raskaan työn
GEMINI_MODEL=gemini-2.5-flash-lite

# Kuinka usein Geminiä kutsutaan (sekunteina). 600 = 10 min.
# Tekninen analyysi (stop-loss, voitto-myynti) pyörii silti joka 60 s.
GEMINI_INTERVAL_SEC=600

# Oppimisraportin Gemini-narratiivi (sekunteina). 21600 = 6 h.
LEARNING_REPORT_INTERVAL_SEC=21600

# Botti uptime-laskenta (valinnainen ISO-aika, esim. 2026-06-10T12:00:00+00:00)
# BOT_STARTED_AT=



# MySQL — Railway: lisää Reference Variable MySQL-palvelusta → MYSQL_URL
# DATABASE_URL=${{MySQL.MYSQL_URL}}
# Älä jätä tyhjää tai rikkinäistä DATABASE_URL:ia — se kaataa deployn.



# Paikallinen MySQL (valinnainen)

# DATABASE_URL=mysql://root:salasana@127.0.0.1:3306/kryptolaatikko



# Historiallinen varjo-oppiminen (Bitfinex 1h-kynttilät)

# BACKFILL_TOP_SYMBOLS=20
# BACKFILL_CANDLE_LIMIT=3000
# HISTORY_BACKFILL_INTERVAL_SEC=604800

