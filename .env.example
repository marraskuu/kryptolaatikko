# Railway Variables (web-palvelu)
SECRET_KEY=generoi-pitka-satunnainen-avain
DEBUG=false
ALLOWED_HOSTS=*

# Oma domain (Railway custom domain)
CUSTOM_DOMAIN=hiekkalaatikko.pro

# Google Gemini (valinnainen — parantaa kaupankäyntipäätöksiä)
# Hae avain: https://aistudio.google.com/apikey
# EI SAA commitoida oikeaa avainta — vain .env paikallisesti tai Railway Variables
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# MySQL — Railway linkittää automaattisesti:
# DATABASE_URL=${{MySQL.MYSQL_URL}}

# Paikallinen MySQL (valinnainen)
# DATABASE_URL=mysql://root:salasana@127.0.0.1:3306/kryptolaatikko
